{
  "name": "nexus",
  "private": true,
  "workspaces": [
    "nexus-platform-web",
    "nexus-platform-worker"
  ],
  "scripts": {
    "dev:web": "cd nexus-platform-web && bun run dev",
    "dev:core": "cd nexus-platform-core && ./mvnw spring-boot:run",
    "dev:worker": "cd nexus-platform-worker && bun run dev",
    "dev:infra": "docker compose up -d",
    "dev:infra:down": "docker compose down",
    "lint:web": "cd nexus-platform-web && bun run lint",
    "lint:worker": "cd nexus-platform-worker && bun run lint",
    "lint:fix": "cd nexus-platform-web && bun run lint:fix && cd ../nexus-platform-worker && bun run lint:fix",
    "build:web": "cd nexus-platform-web && bun run build",
    "build:worker": "cd nexus-platform-worker && bun run build",
    "build:core": "cd nexus-platform-core && ./mvnw clean package -DskipTests",
    "test:worker": "cd nexus-platform-worker && bun run test",
    "test:core": "cd nexus-platform-core && ./mvnw test",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/geist-sans": "^5.2.5",
    "@hono/standard-validator": "^0.2.2",
    "@langchain/anthropic": "^1.3.21",
    "@langchain/core": "^1.1.29",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/openai": "^1.2.11",
    "@langchain/openrouter": "^0.1.4",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-community/standard-openapi": "^0.2.9",
    "@types/json-schema": "^7.0.15",
    "deepagents": "^1.8.3",
    "langchain": "^1.2.32",
    "openapi-types": "^12.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "dotenv": "^16",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "husky": "^9",
    "lint-staged": "^15",
    "prettier": "^3.8.1",
    "tsx": "^4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^3"
  },
  "lint-staged": {
    "nexus-platform-web/**/*.{ts,tsx}": [
      "bunx --bun eslint --fix",
      "bunx --bun prettier --write"
    ],
    "nexus-platform-worker/**/*.{ts,tsx}": [
      "bunx --bun eslint --fix",
      "bunx --bun prettier --write"
    ]
  }
}
